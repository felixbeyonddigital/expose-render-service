<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<style>
/* ---------- Fonts (Montserrat, eingebettet) ---------- */
@font-face { font-family:'Montserrat'; font-weight:300; src:url('assets/fonts/montserrat-latin-300-normal.woff2') format('woff2'); }
@font-face { font-family:'Montserrat'; font-weight:400; src:url('assets/fonts/montserrat-latin-400-normal.woff2') format('woff2'); }
@font-face { font-family:'Montserrat'; font-weight:500; src:url('assets/fonts/montserrat-latin-500-normal.woff2') format('woff2'); }
@font-face { font-family:'Montserrat'; font-weight:600; src:url('assets/fonts/montserrat-latin-600-normal.woff2') format('woff2'); }
@font-face { font-family:'Montserrat'; font-weight:700; src:url('assets/fonts/montserrat-latin-700-normal.woff2') format('woff2'); }
/* latin-ext für Umlaute/ß sicher abgedeckt */
@font-face { font-family:'Montserrat'; font-weight:300; src:url('assets/fonts/montserrat-latin-ext-300-normal.woff2') format('woff2'); unicode-range:U+0100-024F,U+1E00-1EFF,U+20A0-20AB; }
@font-face { font-family:'Montserrat'; font-weight:400; src:url('assets/fonts/montserrat-latin-ext-400-normal.woff2') format('woff2'); unicode-range:U+0100-024F,U+1E00-1EFF,U+20A0-20AB; }
@font-face { font-family:'Montserrat'; font-weight:700; src:url('assets/fonts/montserrat-latin-ext-700-normal.woff2') format('woff2'); unicode-range:U+0100-024F,U+1E00-1EFF,U+20A0-20AB; }

:root{
  /* Standard: Kanzleigrün. Gewerbe-Objekt: Blau (PANTONE 533 C = #202945). */
  --green:{{ '#202945' if gewerbe else '#10231A' }};
  --green-logo:{{ '#202945' if gewerbe else '#10231A' }};
  --gold:#937C4E;
  --stone:#d1cdbc;   /* PANTONE 7534 C „Naturstein grau" (CMYK 0 2 10 18) – Tabellen-/Trennlinien */
  --text:#000000;
  --muted:#333333;
}
* { margin:0; padding:0; box-sizing:border-box; }
@page { size:A4; margin:0; }
html,body{ font-family:'Montserrat',sans-serif; color:var(--text); -weasy-hyphens:auto; }

.page{ position:relative; width:210mm; height:297mm; overflow:hidden; page-break-after:always; }
.page:last-child{ page-break-after:auto; }

/* ---------- Fußzeile ---------- */
.footer{
  position:absolute; left:0; right:0; bottom:9mm;
  text-align:center; font-weight:300; font-size:6.5pt; color:var(--muted);
  letter-spacing:.2px;
}
.footer-logo{
  position:absolute; left:0; right:0; bottom:16mm;
  text-align:center; color:var(--green);          /* Logo per currentColor eingefärbt */
}
.footer-logo svg{ height:15mm; width:auto; display:inline-block; }

/* ---------- Seite 1: Deckblatt (Maße exakt aus Original-MAIL) ---------- */
.cover{ background:var(--green); }
/* DRUCK-Variante (exakt aus InDesign/IDML, Seite 2): weißes Deckblatt (spart
   Druckfarbe). Bild randabfallend oben bis 120 mm, dünner grüner Balken darunter,
   dunkler Titel, KEINE Gold-Balken, Objektnummer mit Linie oben/unten, dunkles Logo, Fußzeile. */
.cover.cover-druck{ background:#ffffff; }
.cover.cover-druck .hero{
  left:0; right:0; top:0; height:120mm; border:none;
}
.cover.cover-druck .druck-stripe{
  position:absolute; left:0; right:0; top:120mm; height:2.5mm; background:var(--green);
}
.cover.cover-druck .accent{ display:none; }            /* im DRUCK keine Gold-Balken */
.cover.cover-druck .titleblock{ top:128mm; }
.cover.cover-druck .title{ color:var(--green); font-size:27pt; }   /* Zeichenstil „A4 V:Überschrift" = 27pt */
/* Objektnummer: rechtsbündig, grün, Gold-/Grün-Balken links, Linien oben+unten (0,5pt Naturstein grau) über die Satzbreite. Logo DARUNTER. */
.cover.cover-druck .druck-objnr{
  position:absolute; left:20mm; right:20mm; top:250mm;
  text-align:right; color:var(--green); font-weight:300; font-size:11pt; letter-spacing:.3px;
  padding:3mm 0; border-top:0.5pt solid var(--stone); border-bottom:0.5pt solid var(--stone);
}
.cover.cover-druck .druck-objnr .bar{ display:inline-block; width:1.6mm; height:3.4mm; background:var(--green); vertical-align:-0.3mm; margin-right:3mm; }
.cover.cover-druck .druck-objnr .lbl{ font-weight:400; }
.cover.cover-druck .druck-objnr b{ font-weight:700; }
.cover.cover-druck .cover-logo{ top:266mm; color:var(--green); }   /* DRUCK: dunkles/blaues Logo auf Weiß */
.cover.cover-druck .cover-logo svg{ height:14mm; }
/* Titelblock zentriert, max. 70% Breite, Umbruch automatisch.
   Der untere Gold-Balken (accent) folgt dem Titel dynamisch – egal ob 1–4 Zeilen. */
.cover .titleblock{
  position:absolute; left:15%; right:15%; top:31mm;
  text-align:center;
}
.cover .accent{
  width:2.5mm; height:4.2mm; background:var(--gold); margin:0 auto;
}
.cover .title{
  color:#ffffff; font-weight:400; font-size:20pt; line-height:1.32;
  margin:6mm 0; word-wrap:break-word; overflow-wrap:break-word;
  -weasy-hyphens:none; hyphens:none;  /* ganze Wörter umbrechen, keine „Aus-blick"-Trennung */
}
.cover .hero{
  position:absolute; left:30mm; right:30mm; top:114mm;
  height:100mm; border:5px solid #ffffff;
}
.cover .hero img{ width:100%; height:100%; object-fit:cover; display:block; }
.cover .cover-logo{
  position:absolute; left:0; right:0; top:243mm; text-align:center;
  color:#ffffff;                                   /* MAIL: weißes Logo auf farbigem Deckblatt */
}
.cover .cover-logo svg{ height:21mm; width:auto; display:inline-block; }

/* ---------- Seite 2: Eckdaten-Tabelle ---------- */
/* Eckdaten-Tabelle exakt aus IDML: Satzbreite 170 mm, Spalte 1 = 60 mm (dann Umbruch),
   Spalte 2 = 110 mm. Durchgehende 0,5-pt-Linien in Naturstein grau – als Flex-Zeilen,
   damit die Linie lückenlos über beide Spalten läuft (keine Zell-Naht) und leere
   Zeilen die Linien behalten. */
.data-wrap{ padding:42mm 20mm 0 20mm; }
.eck{ border-top:0.5pt solid var(--stone); }
.eck-row{
  display:flex; align-items:stretch;
  font-size:11pt; font-weight:300; line-height:1.35;
  border-bottom:0.5pt solid var(--stone);
}
/* Bezeichnungsspalte 60 mm + durchgehende vertikale 0,5-pt-Linie (Naturstein grau) rechts. */
.eck-label{
  flex:0 0 60mm; width:60mm; font-weight:400; color:#1a1a1a;
  padding:7px 6mm 7px 0; border-right:0.5pt solid var(--stone);
}
.eck-value{ flex:1 1 auto; text-align:right; white-space:pre-line; padding:7px 0 7px 6mm; }
.objnr{
  position:absolute; right:22mm; bottom:52mm;
  font-size:11pt; color:var(--green-logo);
}
.objnr .bar{ display:inline-block; width:6px; height:13px; background:var(--green-logo); vertical-align:-1px; margin-right:8px; }
.objnr b{ font-weight:700; }
.objnr .lbl{ font-weight:400; letter-spacing:.5px; }

/* ---------- Seite 3: Beschreibung ---------- */
.desc{ padding:30mm 22mm 0 22mm; }
.desc p{ font-size:11pt; font-weight:300; line-height:1.55; text-align:justify; margin-bottom:9pt; }
.desc p strong{ font-weight:400; }  /* Hervorhebung = Regular (nicht fett), wie Original */

/* ---------- Fotoseiten ---------- */
.photos{ padding:14mm 14mm 0 14mm; }
.photo-row{ width:100%; height:88mm; margin-bottom:6mm; }
.photo-row:last-child{ margin-bottom:0; }
.photo-row.pair{ display:flex; }
.photo-row.pair .cell{ flex:1 1 0; height:100%; }
.photo-row.pair .cell:first-child{ margin-right:6mm; }
.photo-row img{ width:100%; height:100%; object-fit:cover; display:block; }
/* Höhe je Format: quadratisch (Standard), hochformat, querformat + Einzelbilder */
.photo-row.row-square{ height:88mm; }
.photo-row.row-portrait{ height:117mm; }
.photo-row.row-landscape{ height:100mm; }
.photo-row.row-square_single{ height:120mm; }
.photo-row.row-portrait_single{ height:150mm; }

/* ---------- Grundriss ---------- */
.plan-wrap{ padding:26mm 18mm 0 18mm; text-align:center; }
.plan-wrap img{ max-width:100%; max-height:190mm; object-fit:contain; }
.plan-caption{ position:absolute; right:20mm; bottom:70mm; font-size:15pt; font-weight:300; color:#555; }

/* ---------- Seite 8: Disclaimer ---------- */
.bleed{ position:relative; width:100%; height:118mm; }
.bleed img{ width:100%; height:100%; object-fit:cover; display:block; }
.bleed .stripe{ position:absolute; left:0; right:0; bottom:0; height:6mm; background:var(--green); }
.legal{ padding:16mm 22mm 0 22mm; }
.legal h3{ font-size:11pt; font-weight:700; margin-bottom:10pt; }
.legal p{ font-size:11pt; font-weight:300; line-height:1.5; text-align:justify; margin-bottom:9pt; white-space:pre-line; }
</style>
</head>
<body>

<!-- ===== Seite 1: Deckblatt ===== -->
<div class="page cover{% if druck %} cover-druck{% endif %}">
  <div class="hero"><img src="{{ titelbild }}"></div>
  {% if druck %}<div class="druck-stripe"></div>{% endif %}
  <div class="titleblock">
    <div class="accent"></div>
    <div class="title">{{ titel_zeile1 }}{% if titel_zeile2 %}<br>{{ titel_zeile2 }}{% endif %}</div>
    <div class="accent"></div>
  </div>
  {% if druck %}<div class="druck-objnr"><span class="bar"></span><span class="lbl">Objektnummer</span> <b>{{ objektnummer }}</b></div>{% endif %}
  <div class="cover-logo">{{ logo_svg|safe }}</div>
  {% if druck %}<div class="footer">{{ footer }}</div>{% endif %}
</div>

<!-- ===== Seite 2: Eckdaten ===== -->
<div class="page">
  <div class="data-wrap">
    <div class="eck">
      {% for row in eckdaten %}
        {% if row.spacer %}<div class="eck-row"><div class="eck-label">&nbsp;</div><div class="eck-value"></div></div>
        {% else %}<div class="eck-row"><div class="eck-label">{{ row.label }}</div><div class="eck-value">{{ row.value }}</div></div>{% endif %}
      {% endfor %}
    </div>
  </div>
  <div class="objnr"><span class="bar"></span><span class="lbl">OBJEKTNUMMER</span> <b>{{ objektnummer }}</b></div>
  <div class="footer-logo">{{ logo_svg|safe }}</div>
  <div class="footer">{{ footer }}</div>
</div>

<!-- ===== Seite 3: Beschreibung ===== -->
<div class="page">
  <div class="desc">
    {% for absatz in beschreibung %}<p>{{ absatz|safe }}</p>{% endfor %}
  </div>
  <div class="footer-logo">{{ logo_svg|safe }}</div>
  <div class="footer">{{ footer }}</div>
</div>

<!-- ===== Fotoseiten ===== -->
{% for seite in fotoseiten %}
<div class="page">
  <div class="photos">
    {% for row in seite %}
      {% if row.cells|length == 2 %}
      <div class="photo-row pair row-{{ row.type }}">
        <div class="cell"><img src="{{ row.cells[0] }}"></div>
        <div class="cell"><img src="{{ row.cells[1] }}"></div>
      </div>
      {% else %}
      <div class="photo-row row-{{ row.type }}"><img src="{{ row.cells[0] }}"></div>
      {% endif %}
    {% endfor %}
  </div>
  <div class="footer-logo">{{ logo_svg|safe }}</div>
  <div class="footer">{{ footer }}</div>
</div>
{% endfor %}

<!-- ===== Grundriss ===== -->
{% if grundriss %}
<div class="page">
  <div class="plan-wrap"><img src="{{ grundriss }}"></div>
  <div class="plan-caption">Grundriss</div>
  <div class="footer-logo">{{ logo_svg|safe }}</div>
  <div class="footer">{{ footer }}</div>
</div>
{% endif %}

<!-- ===== Seite 8: Disclaimer ===== -->
<div class="page">
  {% if disclaimer_bild %}
  <div class="bleed"><img src="{{ disclaimer_bild }}"><div class="stripe"></div></div>
  {% endif %}
  <div class="legal">
    {% if rechtstext_heading %}<h3>{{ rechtstext_heading }}</h3>{% endif %}
    {% for absatz in rechtstext %}<p>{{ absatz }}</p>{% endfor %}
  </div>
  <div class="footer-logo">{{ logo_svg|safe }}</div>
  <div class="footer">{{ footer }}</div>
</div>

</body>
</html>
